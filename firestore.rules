rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — only the owner can write their own doc
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Projects — any auth user can read; only owner can write
    match /projects/{projectId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;

      // Milestones subcollection
      match /milestones/{milestoneId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
          && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;
      }
    }

    // Feed items — any auth user can read/create; only owner can update/delete
    match /feedItems/{feedItemId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update: if request.auth != null
        && (resource.data.ownerId == request.auth.uid
            || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['raiseHandCount']));
      allow delete: if request.auth != null && resource.data.ownerId == request.auth.uid;

      // Comments subcollection
      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid;
        allow delete: if request.auth != null && resource.data.authorId == request.auth.uid;
      }

      // Raise hands subcollection — doc ID is userId
      match /raiseHands/{userId} {
        allow read: if request.auth != null
          && (request.auth.uid == userId
              || get(/databases/$(database)/documents/feedItems/$(feedItemId)).data.ownerId == request.auth.uid);
        allow create, update, delete: if request.auth != null && request.auth.uid == userId;
        // Owner can update status (accept/dismiss)
        allow update: if request.auth != null
          && get(/databases/$(database)/documents/feedItems/$(feedItemId)).data.ownerId == request.auth.uid;
      }
    }
  }
}
